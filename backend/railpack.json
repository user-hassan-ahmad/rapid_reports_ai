{
  "$schema": "https://schema.railpack.com",
  "steps": {
    "install": {
      "commands": [
        { "src": "pyproject.toml", "dest": "pyproject.toml" },
        { "src": "poetry.lock", "dest": "poetry.lock" },
        "poetry config virtualenvs.in-project true",
        "poetry install --no-interaction --no-ansi --only main"
      ]
    }
  }
}
