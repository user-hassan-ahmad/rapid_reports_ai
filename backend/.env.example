# Radflow backend environment template.
# Copy to .env and fill in real values. Do not commit .env.

# --- Core ---
DATABASE_URL=postgresql://user:pass@localhost:5432/rapid_reports
SECRET_KEY=change-me-to-a-long-random-string
FRONTEND_URL=https://rad-flow.uk

# --- Admin approval gate ---
# Recipient of new-sign-up approval emails. One-click approve/reject links are
# HMAC-signed with SECRET_KEY and land on /api/admin/{approve,reject}.
ADMIN_NOTIFICATION_EMAIL=hass.ahmad.95@gmail.com
# Base URL used to construct approve/reject links in the admin notification.
# Must match the public origin where the backend serves /api/admin/*.
ADMIN_API_BASE_URL=https://radflow.app

# --- Email (Resend preferred, SMTP fallback) ---
RESEND_API_KEY=
RESEND_FROM_EMAIL=RadFlow <onboarding@resend.dev>
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
